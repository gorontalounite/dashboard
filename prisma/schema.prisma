generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reports   Report[]
}

model Report {
  id           String        @id @default(cuid())
  title        String
  accountName  String
  periodStart  DateTime
  periodEnd    DateTime
  shareToken   String        @unique @default(cuid())
  isPublic     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userId       String
  audienceData AudienceData?
  dailyMetrics DailyMetric[]
  metrics      Metrics?
  postInsights PostInsight[]
  createdBy    User          @relation(fields: [userId], references: [id])
}

model Metrics {
  id            String @id @default(cuid())
  reportId      String @unique
  views         Int    @default(0)
  accountsReached Int  @default(0)
  interactions  Int    @default(0)
  likes         Int    @default(0)
  comments      Int    @default(0)
  saves         Int    @default(0)
  shares        Int    @default(0)
  followsGained Int    @default(0)
  profileVisits Int    @default(0)
  report        Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model AudienceData {
  id          String  @id @default(cuid())
  reportId    String  @unique
  genderMen   Float   @default(0)
  genderWomen Float   @default(0)
  age13to17   Float   @default(0)
  age18to24   Float   @default(0)
  age25to34   Float   @default(0)
  age35to44   Float   @default(0)
  age45to54   Float   @default(0)
  age55to64   Float   @default(0)
  age65plus   Float   @default(0)
  topCity1    String?
  topCity1Pct Float   @default(0)
  topCity2    String?
  topCity2Pct Float   @default(0)
  topCity3    String?
  topCity3Pct Float   @default(0)
  topCity4    String?
  topCity4Pct Float   @default(0)
  topCity5    String?
  topCity5Pct Float   @default(0)
  report      Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model DailyMetric {
  id            String   @id @default(cuid())
  reportId      String
  date          DateTime
  views         Int      @default(0)
  reach         Int      @default(0)
  interactions  Int      @default(0)
  follows       Int      @default(0)
  profileVisits Int      @default(0)
  linkClicks    Int      @default(0)
  report        Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, date])
}

model PostInsight {
  id          String      @id @default(cuid())
  reportId    String
  postId      String?
  permalink   String?
  caption     String?
  type        ContentType @default(REELS)
  publishedAt DateTime?
  views       Int         @default(0)
  reach       Int         @default(0)
  likes       Int         @default(0)
  comments    Int         @default(0)
  saves       Int         @default(0)
  shares      Int         @default(0)
  follows     Int         @default(0)
  duration    Int         @default(0)
  report      Report      @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  VIEWER
}

enum ContentType {
  REELS
  STORIES
  POSTS
  VIDEOS
}